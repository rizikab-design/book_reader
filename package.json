{
  "name": "book-reader",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "electron:dev": "npm run build:web && electron electron/main.js",
    "electron:build": "npm run build:web && electron-builder --mac"
  },
  "dependencies": {
    "@epubjs-react-native/core": "^1.4.7",
    "@epubjs-react-native/expo-file-system": "^1.1.4",
    "@react-navigation/native": "^7.1.28",
    "epubjs": "^0.3.93",
    "expo": "~55.0.5",
    "expo-asset": "~55.0.8",
    "expo-constants": "~55.0.7",
    "expo-file-system": "~55.0.10",
    "expo-font": "~55.0.4",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.4",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-web-browser": "~55.0.9",
    "pdfjs-dist": "^3.11.174",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "typescript": "~5.9.2"
  },
  "build": {
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "appId": "com.bookReader.app",
    "productName": "Book Reader",
    "mac": {
      "category": "public.app-category.books",
      "target": "dir"
    },
    "files": [
      "electron/**/*",
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "server",
        "to": "server",
        "filter": [
          "**/*",
          "node_modules/**/*",
          "!books/**",
          "!covers/**",
          "!library.json"
        ]
      }
    ]
  },
  "private": true
}
